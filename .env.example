# Gemini API
GEMINI_API_KEY=

# Google Drive OAuth2
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=

# Admin Authentication (legacy — kept for backward compat)
ADMIN_PASSWORD=

# Initial admin account (created automatically on first startup if no users exist)
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=

# Database
DATABASE_PATH=./data/hoortrad.db

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mode simulation (true = proxys simulés, false = vrais encodages via ffmpeg)
SIMULATION_MODE=false

# Chemin de l'exécutable ffmpeg (laisser "ffmpeg" si disponible dans le PATH)
FFMPEG_PATH=ffmpeg

# Chemin de l'exécutable ffprobe (laisser "ffprobe" si disponible dans le PATH)
FFPROBE_PATH=ffprobe

# Timeout pour un encodage de proxy (en millisecondes) — 2h par défaut
PROXY_TIMEOUT_MS=7200000

# Partages réseau UNC affichés dans la modale "Parcourir" (séparés par |)
# Exemple : \\SERVEUR\Partage1|\\SERVEUR\Partage2
NETWORK_SHARES=

# Conversion lettre → UNC pour les chemins collés (séparés par virgule)
# Exemple : M:=\\SERVEUR\Partage1,N:=\\SERVEUR\Partage2
DRIVE_LETTER_MAP=
